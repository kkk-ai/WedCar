<link
	rel="stylesheet"
	href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
	integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
	crossorigin=""
>

<style>
	.footer-map-section {
		background: linear-gradient(135deg, #1f3b5b 55%);
		color: #fff;
		padding: 60px 20px 48px;
		margin-top: 0;
	}

	.footer-map-shell {
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-map-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 36px;
		flex-wrap: wrap;
	}

	.footer-map-header-content {
		flex: 1;
		min-width: 300px;
	}

	.footer-map-title {
		margin: 0;
		font-size: 28px;
		line-height: 1.2;
		font-weight: 700;
		color: #fff;
	}

	.footer-map-subtitle {
		margin: 12px 0 0;
		max-width: 620px;
		color: rgba(255, 255, 255, 0.8);
		font-size: 14px;
		line-height: 1.6;
	}

	.footer-map-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0;
		align-items: stretch;
		margin-bottom: 20px;
	}

	.footer-map-card {
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 12px;
		backdrop-filter: blur(10px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
		overflow: hidden;
	}

	#footerStoreMap {
		width: 100%;
		height: 420px;
		background: rgba(255, 255, 255, 0.12);
	}

	.footer-map-status {
		margin: 0;
		padding: 16px 20px;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.84);
		background: rgba(0, 0, 0, 0.1);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.footer-empty-panel {
		display: none;
	}

	.footer-map-footer {
		max-width: 1200px;
		margin: 24px auto 0;
		padding-top: 24px;
		border-top: 1px solid rgba(255, 255, 255, 0.14);
		color: rgba(255, 255, 255, 0.68);
		font-size: 13px;
		display: flex;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
		line-height: 1.6;
	}

	.footer-map-footer a {
		color: #ffd166;
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.footer-map-footer a:hover {
		color: #ffed4e;
	}

	.leaflet-popup-content-wrapper,
	.leaflet-popup-tip {
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
	}

	@media (max-width: 900px) {
		.footer-map-section {
			padding: 48px 20px 40px;
		}

		.footer-map-header {
			flex-direction: column;
		}

		#footerStoreMap {
			height: 400px;
		}
	}

	@media (max-width: 600px) {
		.footer-map-section {
			padding: 40px 16px 32px;
		}

		.footer-map-title {
			font-size: 24px;
		}

		.footer-map-subtitle {
			font-size: 13px;
		}

		#footerStoreMap {
			height: 320px;
		}

		.footer-map-footer {
			flex-direction: column;
		}
	}
</style>

<footer class="footer-map-section">
	<div class="footer-map-shell">
		<div class="footer-map-header">
			<div class="footer-map-header-content">
				<h2 class="footer-map-title">Hệ thống cửa hàng WedCar</h2>
				<p class="footer-map-subtitle">
					Bản đồ bên dưới lấy dữ liệu trực tiếp từ hệ thống cửa hàng để khách hàng dễ tìm chi nhánh gần nhất.
				</p>
			</div>
		</div>

		<div class="footer-map-grid">
			<div class="footer-map-card">
				<div id="footerStoreMap"></div>
				<p class="footer-map-status" id="footerStoreStatus">Đang tải dữ liệu cửa hàng...</p>
			</div>

			<div class="footer-map-card footer-empty-panel" aria-hidden="true"></div>
		</div>
	</div>

	
</footer>

<script
	src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
	integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
	crossorigin=""
></script>

<script>
	(function () {
		const mapElement = document.getElementById('footerStoreMap');
		const statusElement = document.getElementById('footerStoreStatus');

		if (!mapElement || !statusElement || typeof L === 'undefined') {
			return;
		}

		const defaultCenter = [16.047079, 108.20623];
		const map = L.map(mapElement, {
			scrollWheelZoom: false
		}).setView(defaultCenter, 6);

		function syncMapSize() {
			window.requestAnimationFrame(function () {
				map.invalidateSize();
			});
		}

		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			maxZoom: 19,
			attribution: '&copy; OpenStreetMap contributors'
		}).addTo(map);

		syncMapSize();
		window.addEventListener('load', syncMapSize);
		window.addEventListener('resize', syncMapSize);

		if (typeof ResizeObserver !== 'undefined') {
			const mapObserver = new ResizeObserver(function () {
				syncMapSize();
			});
			mapObserver.observe(mapElement);
		}

		const markers = [];

		function escapeHtml(value) {
			return String(value || '')
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#39;');
		}

		function buildCacheKey(store) {
			return ['wedcar-store-geocode', store._id, store.diaChi || ''].join(':');
		}

		function getStoredCoordinates(store) {
			const lat = Number(store.latitude);
			const lng = Number(store.longitude);

			if (!Number.isNaN(lat) && !Number.isNaN(lng) && lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180) {
				return { lat: lat, lng: lng, source: 'stored' };
			}

			return null;
		}

		function readCachedCoordinates(store) {
			try {
				const cached = window.localStorage.getItem(buildCacheKey(store));
				return cached ? JSON.parse(cached) : null;
			} catch (error) {
				return null;
			}
		}

		function saveCachedCoordinates(store, coords) {
			try {
				window.localStorage.setItem(buildCacheKey(store), JSON.stringify(coords));
			} catch (error) {
				return;
			}
		}

		async function geocodeAddress(store) {
			if (!store.diaChi) {
				return null;
			}

			const cached = readCachedCoordinates(store);
			if (cached && typeof cached.lat === 'number' && typeof cached.lng === 'number') {
				return cached;
			}

			const query = encodeURIComponent(store.diaChi + ', Viet Nam');
			const response = await fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=' + query, {
				headers: {
					Accept: 'application/json'
				}
			});

			if (!response.ok) {
				return null;
			}

			const results = await response.json();
			if (!Array.isArray(results) || results.length === 0) {
				return null;
			}

			const coords = {
				lat: Number(results[0].lat),
				lng: Number(results[0].lon)
			};

			if (Number.isNaN(coords.lat) || Number.isNaN(coords.lng)) {
				return null;
			}

			saveCachedCoordinates(store, coords);
			return {
				lat: coords.lat,
				lng: coords.lng,
				source: 'geocoded'
			};
		}

		async function loadStoreMap() {
			try {
				const response = await fetch('/api/cuahang/api/list');
				const stores = await response.json();

				if (!response.ok || !Array.isArray(stores)) {
					throw new Error('Không thể tải danh sách cửa hàng');
				}

				const mappedStoreIds = new Set();
				const bounds = [];
				let geocodedCount = 0;
				let storedCoordCount = 0;

				for (const store of stores) {
					const coords = getStoredCoordinates(store) || await geocodeAddress(store);
					if (!coords) {
						continue;
					}

					if (coords.source === 'stored') {
						storedCoordCount += 1;
					} else {
						geocodedCount += 1;
					}

					mappedStoreIds.add(String(store._id));
					bounds.push([coords.lat, coords.lng]);

					const popupHtml = [
						'<strong>' + escapeHtml(store.tenCuaHang || 'Cửa hàng WedCar') + '</strong><br>',
						escapeHtml('Địa chỉ: ' + (store.diaChi || 'Chưa có địa chỉ')) + '<br>',
						escapeHtml('SĐT: ' + (store.soDienThoai || 'Chưa có số điện thoại'))
					].join('');

					const marker = L.marker([coords.lat, coords.lng]).addTo(map).bindPopup(popupHtml);
					markers.push(marker);
				}

				if (bounds.length) {
					map.fitBounds(bounds, {
						padding: [30, 30]
					});
					statusElement.textContent = 'Đang hiển thị ' + bounds.length + ' cửa hàng. Dùng tọa độ đã lưu: ' + storedCoordCount + ', định vị từ địa chỉ: ' + geocodedCount + '.';
				} else {
					statusElement.textContent = 'Không thể định vị cửa hàng nào từ dữ liệu địa chỉ hiện tại.';
				}
			} catch (error) {
				statusElement.textContent = 'Không tải được bản đồ cửa hàng lúc này.';
			} finally {
				window.setTimeout(syncMapSize, 100);
				window.setTimeout(syncMapSize, 350);
			}
		}

		loadStoreMap();
	})();
</script>
