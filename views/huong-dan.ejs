  <%- include('footer') %>

  <script>
    // FAQ Data
    const faqData = [
      {
        question: "Có phí ẩn nào không?",
        answer: "Không có phí ẩn. Tất cả các phí sẽ được hiển thị rõ ràng trước khi bạn thanh toán, bao gồm phí giao xe, bảo hiểm, phí dịch vụ, v.v. Bạn sẽ thấy tổng giá hoàn chỉnh trước khi xác nhận tuần."
      },
      {
        question: "Tôi có thể hủy đơn hàng không?",
        answer: "Có, bạn có thể hủy đơn hàng trước khi cửa hàng xác nhận. Sau khi hủy, tiền sẽ được hoàn lại vào tài khoản của bạn trong vòng 3-5 ngày làm việc. Nếu xin hủy sau khi có xác nhận, có thể sẽ bị tính phí hủy."
      },
      {
        question: "Nếu xe gặp sự cố thì sao?",
        answer: "Nếu xe gặp sự cố sau khi bạn nhận, hãy liên hệ ngay cửa hàng. Chúng tôi sẽ giúp bạn đổi xe khác hoặc hoàn tiền. Tất cả xe đều được bảo hiểm đầy đủ."
      },
      {
        question: "Có hỗ trợ tiếng Anh không?",
        answer: "Hiện tại, WedCar chủ yếu hỗ trợ tiếng Việt. Tuy nhiên, bạn có thể liên hệ qua điện thoại hoặc email, và chúng tôi sẽ cố gắng hỗ trợ bằng tiếng Anh."
      },
      {
        question: "Làm sao để nhập mã khuyến mãi?",
        answer: "Khi bạn đang ở bước thanh toán, sẽ có một ô nhập 'Mã khuyến mãi' hoặc 'Mã giảm giá'. Nhập mã vào đó và nhấp 'Áp dụng'. Giá sẽ tự động giảm nếu mã hợp lệ."
      },
      {
        question: "Có bảo hiểm cho xe không?",
        answer: "Có. Tất cả xe trên WedCar đều được bảo hiểm. Khi đặt mua hoặc thuê, bảo hiểm sẽ được bao gồm trong giá hoặc tính riêng. Bạn sẽ thấy rõ ràng trong hóa đơn."
      },
      {
        question: "Tôi có thể thêm người khác vào hợp đồng không?",
        answer: "Nếu bạn muốn thêm người khác, hãy liên hệ trực tiếp cửa hàng. Họ sẽ cập nhật hợp đồng và yêu cầu CCCD/Hộ chiếu của người đó."
      },
      {
        question: "Có yêu cầu tuổi tối thiểu để sử dụng dịch vụ không?",
        answer: "Có, bạn cần tối thiểu 18 tuổi để đăng ký tài khoản. Để thuê/mua xe, tuổi tối thiểu có thể từ 18-21 tuổi tùy loại xe và chính sách cửa hàng."
      }
    ];

    // Render FAQ
    function renderFAQ() {
      const container = document.getElementById('faqContainer');
      faqData.forEach((item, index) => {
        const faqHTML = `
          <div class="faq-item">
            <div class="faq-question" onclick="toggleFAQ(${index})">
              <span>${item.question}</span>
              <i class="bi bi-chevron-down"></i>
            </div>
            <div class="faq-answer" id="faq-${index}">
              <p>${item.answer}</p>
            </div>
          </div>
        `;
        container.innerHTML += faqHTML;
      });
    }

    // Toggle FAQ
    function toggleFAQ(index) {
      const answer = document.getElementById(`faq-${index}`);
      const question = answer.previousElementSibling;
      
      answer.classList.toggle('show');
      question.classList.toggle('active');
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', renderFAQ);
  </script>
</body>
</html>
