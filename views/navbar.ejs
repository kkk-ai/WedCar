<script>
function dangXuat() {
    if (confirm('Bạn chắc chắn muốn đăng xuất?')) {
        fetch('/auth/dang-xuat', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            alert('✅ Đăng xuất thành công');
            window.location.href = '/';
        })
        .catch(error => {
            alert('❌ Lỗi khi đăng xuất: ' + error.message);
        });
    }
}
</script>

